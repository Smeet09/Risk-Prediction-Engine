# =============================================================
# Aether-Disaster — GIS FastAPI Microservice Environment
# =============================================================

# FastAPI server
HOST=0.0.0.0
PORT=8000

# Database (same PostGIS instance as backend)
DATABASE_URL=postgresql://aether:aether_secret@localhost:5432/aether_disaster

# Data root — must match backend DATA_ROOT (portable)
DATA_ROOT=../database

# ERA5 / Copernicus CDS API credentials
# Get your key at: https://cds.climate.copernicus.eu/user/register
CDS_URL=https://cds.climate.copernicus.eu/api/v2
CDS_KEY=your-uid:your-api-key

# Processing flags
DEM_STUB_MODE=true       # Set false when you plug in your real DEM script
SUSC_STUB_MODE=true      # Set false when you plug in your AHP script
