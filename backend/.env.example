# =============================================================
# Aether-Disaster — Backend Environment Variables
# =============================================================

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://aether:aether_secret@localhost:5432/aether_disaster

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

# Data storage root — portable, set to absolute path when moving project
# On Windows: DATA_ROOT=D:\my-data\aether
# On Linux/Mac: DATA_ROOT=/opt/aether/data
DATA_ROOT=../database

# FastAPI GIS Service
GIS_SERVICE_URL=http://localhost:8000

# Default admin credentials (change after first run!)
ADMIN_EMAIL=admin@aether.local
ADMIN_PASSWORD=Admin@1234
